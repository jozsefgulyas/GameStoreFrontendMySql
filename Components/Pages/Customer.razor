@page "/customers"
@inject CustomersClient Client
@attribute [StreamRendering]

<PageTitle>Customer List</PageTitle>

<div class="mt-2">
    <a class="btn btn-primary" role="button" href="/editcustomer">New Customer</a>
</div>

@if(customers is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table table-striped table-bordered table-hover mt-3">
        <thead class="table-dark">
            <th>Id</th>
            <th>Name</th>
            <th>Genre</th>
            <th class="text-end">Price</th>
            <th>Release Date</th>
            <th></th>
        </thead>
        <tbody>
            @foreach (var customer in customers){
                <tr>
                    <td>@customer.Id</td>
                    <td>@customer.Name</td>
                    <td>@customer.Email</td>
                    <td>@customer.DateOfBirth</td>
                    <td>@customer.Address</td>
                    <td>
                        <div class="d-flex">
                            <a class="btn btn-primary me-2" role="button" href="@CustomerUrl(customer.Id)">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <button class="btn btn-danger" 
                                    data-bs-toggle="modal" 
                                    data-bs-target="@GetDeleteModalId(customer)">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                        <DeleteCustomer Customer="@customer" />
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private CustomerDetails[]? customers;

    protected override async Task OnInitializedAsync()
    {
        customers = await Client.GetCustomersAsync();
    }

    private static string CustomerUrl(int id) => $"/editcustomer/{id}";

    private string GetDeleteModalId(CustomerDetails customer)
    {
        return $"#{DeleteCustomer.GetModalId(customer)}";
    }
}