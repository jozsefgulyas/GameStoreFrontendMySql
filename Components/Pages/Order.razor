@page "/orders"
@inject OrdersClient ordersClient
@inject CustomersClient customersClient
@inject GamesClient gamesClient
@inject NavigationManager nav

@attribute [StreamRendering]

@rendermode InteractiveServer
<PageTitle>Order Catalog</PageTitle>

<div class="mt-2">
    <button class="btn btn-primary" @onclick='() => nav.NavigateTo("/editorder")'>New Order</button>
    <button class="btn btn-primary" @onclick='() => nav.NavigateTo("/games")'>Games</button>
    <button class="btn btn-primary" @onclick='() => nav.NavigateTo("/customers")'>Customers</button>
    <input type="checkbox" id="IsOrderComplete" checked="@IsOrderCompleteOnly"
       @onchange="(ChangeEventArgs e) => IsOrderCompleteOnly = e.Value as bool? ?? false" />
    <label for="IsOrderComplete" class="form-check-label">Show only completed orders</label>    
</div>
<p><small class="text-muted">Showing @FilteredOrders.Count() of @(orders?.Length ?? 0) orders.</small></p>

@if(orders is null || customers is null || games is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table table-striped table-bordered table-hover mt-3">
        <thead class="table-dark">
            <th>Id</th>
            <th>Customer Id</th>
            <th>Game Id</th>
            <th>Purchase Date</th>
            <th>Quantity</th>
            <th>IsOrderCompleted</th>
            <th></th>
        </thead>
        <tbody>
            @foreach (var (order, index) in FilteredOrders.Select((o, i) => (o, i)))
            {
                <tr>
                    <td>@(index+1)</td>
                    <td>@customers.FirstOrDefault(c => c.Id == order.CustomerId)?.Name</td>
                    <td>@games.FirstOrDefault(g => g.Id == order.GameId)?.Name</td>
                    <td>@order.PurchaseDate</td>
                    <td>@order.Quantity</td>
                    <td>@if (order.IsOrderComplete)
                        {
                            <span class="badge bg-success">Yes</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">No</span>
                        } 
                    </td>
                    <td>
                        <div class="d-flex">
                            <a class="btn btn-primary me-2" role="button" href="@OrderUrl(order.Id)">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <button class="btn btn-danger" 
                                    data-bs-toggle="modal" 
                                    data-bs-target="@GetDeleteModalId(order)">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                        <DeleteOrder Order="@order" />
                    </td>
                </tr>
                }
        </tbody>
    </table>
}

@code {
    private OrderDetails[]? orders;
    private CustomerDetails[]? customers;
    private GameSummary[]? games;
    private bool IsOrderCompleteOnly { get; set; }

    private IEnumerable<OrderDetails> FilteredOrders => orders == null
        ? Enumerable.Empty<OrderDetails>()
        : IsOrderCompleteOnly
            ? orders.Where(o => o.IsOrderComplete)
            : orders;

   protected override async Task OnInitializedAsync()
    {
     try
        {
            orders = await ordersClient.GetOrdersAsync();
            customers = await customersClient.GetCustomersAsync();
            games = await gamesClient.GetGamesAsync();
        }
    catch (Exception ex)
        {
            Console.WriteLine("Load list error: " + ex);
            throw;
        }
    }

    private static string OrderUrl(int id) => $"/editorder/{id}";

    private string GetDeleteModalId(OrderDetails order)
    {
        return $"#{DeleteOrder.GetModalId(order)}";
    }
}